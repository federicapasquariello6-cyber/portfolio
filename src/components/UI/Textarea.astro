---
const { id, label, placeholder, rows = 6 } = Astro.props;
---

<div class="space-y-2">

  <label for={id} class="text-sm font-medium text-white/70">
    {label}
  </label>

  <textarea
    id={id}
    name={id}
    rows={rows}
    placeholder={placeholder}
    required
    class="
      w-full resize-none rounded-lg
      border border-white/10
      bg-white/5
      px-4 py-3
      text-white
      placeholder:text-white/30
      outline-none
      backdrop-blur
      transition

      focus:border-[#7c5cff]
      focus:ring-2
      focus:focus:ring-[#7c5cff]/10 focus:shadow-[0_0_0_3px_rgba(124,92,255,0.15)]
    "
  ></textarea>

</div>