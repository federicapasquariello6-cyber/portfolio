---
const { id, label, type = "text", placeholder } = Astro.props;
---

<div class="space-y-2">

  <label for={id} class="text-sm font-medium text-white/70">
    {label}
  </label>

  <input
    id={id}
    name={id}
    type={type}
    placeholder={placeholder}
    required
    class="
      w-full rounded-lg
      border border-white/10
      bg-white/5
      px-4 py-3
      text-white
      placeholder:text-white/30
      outline-none
      backdrop-blur
      transition

      focus:border-[#7c5cff]
      focus:ring-2
      focus:ring-[#7c5cff]/20
    "
  />

</div>