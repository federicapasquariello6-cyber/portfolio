---
const { href, type = "button" } = Astro.props;
---

{href ? (
  <a
    href={href}
    class="inline-flex items-center justify-center rounded-lg bg-[#7c5cff] px-6 py-3 text-sm font-semibold text-white transition
           hover:-translate-y-1 hover:shadow-[0_0_25px_rgba(124,92,255,0.35)]
           active:scale-[0.98]"
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    class="inline-flex items-center justify-center rounded-lg bg-[#7c5cff] px-6 py-3 text-sm font-semibold text-white transition
           hover:-translate-y-1 hover:shadow-[0_0_25px_rgba(124,92,255,0.35)]
           active:scale-[0.98]"
  >
    <slot />
  </button>
)}