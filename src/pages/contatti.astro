---
import Layout from "../layout/Layout.astro";
---

<Layout title="FP Portfolio - Contatti">
  <section class="max-w-2xl space-y-8">
    <div class="space-y-4">
      <p class="text-sm uppercase tracking-widest text-cyan-300">
        Contatti
      </p>

      <h1 class="text-4xl sm:text-5xl font-bold">
        Scrivimi un messaggio
      </h1>

      <p class="text-slate-400">
        Puoi usare questo form per contattarmi, farmi una domanda o lasciare un feedback sul portfolio.
      </p>
    </div>

<form method="POST" action="/api/contatto" class="space-y-5 bg-slate-900 border border-slate-800 rounded-lg p-6">      <div class="space-y-2">
        <label for="name" class="block text-sm text-slate-300">
          Nome
        </label>
        <input
          id="name"
          name="name"
          type="text"
          required
          class="w-full rounded-lg bg-slate-950 border border-slate-700 px-4 py-3 text-slate-100 outline-none focus:border-cyan-400"
        />
      </div>

      <div class="space-y-2">
        <label for="email" class="block text-sm text-slate-300">
          Email
        </label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="w-full rounded-lg bg-slate-950 border border-slate-700 px-4 py-3 text-slate-100 outline-none focus:border-cyan-400"
        />
      </div>

      <div class="space-y-2">
        <label for="message" class="block text-sm text-slate-300">
          Messaggio
        </label>
        <textarea
          id="message"
          name="message"
          rows="6"
          required
          class="w-full rounded-lg bg-slate-950 border border-slate-700 px-4 py-3 text-slate-100 outline-none focus:border-cyan-400"
        ></textarea>
      </div>

      <button
        type="submit"
        class="bg-cyan-300 text-slate-950 px-6 py-3 rounded-lg font-semibold hover:scale-105 transition"
      >
        Invia messaggio
      </button>
    </form>
  </section>
</Layout>
