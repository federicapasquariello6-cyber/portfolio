---
import Layout from "../layout/Layout.astro";

const skills = [
  "Astro",
  "Tailwind",
  "HTML",
  "CSS",
  "JavaScript",
  "Node.js",
  "GitHub",
  "Vercel",
];

const strengths = [
  "Metodo tecnico",
  "Attenzione ai dettagli",
  "Curiosità digitale",
];
---

<Layout title="Federica Pasquariello | Frontend Developer">

  <!-- HERO -->
  <section class="min-h-[85vh] flex items-center py-20">
    <div class="max-w-6xl w-full grid md:grid-cols-2 gap-12 items-center">

      <!-- LEFT -->
      <div>

        <p class="text-white/60 text-sm uppercase tracking-[0.25em] animate-fadeUp">
          Frontend Developer
        </p>

        <h1 class="mt-6 text-5xl md:text-7xl font-bold leading-[1.05] text-white animate-fadeUp">
          Federica <br />
          Pasquariello
        </h1>

        <h2 class="mt-6 text-xl text-white/70 animate-fadeUp">
          Laureata in Ingegneria Energetica
        </h2>

        <p class="mt-8 max-w-xl text-white/60 leading-relaxed animate-fadeUp">
          Progetto interfacce web moderne e minimaliste, unendo approccio ingegneristico e attenzione al design.
        </p>

        <div class="mt-10 flex flex-wrap gap-4 animate-fadeUp">

          <a
            href="/progetti"
            class="px-6 py-3 rounded-xl bg-[#7c5cff] text-white font-medium hover:translate-y-[-2px] transition"
          >
            I miei progetti
          </a>

          <a
            href="/contatti"
            class="px-6 py-3 rounded-xl border border-white/20 text-white/80 hover:border-white hover:text-white transition"
          >
            Contattami
          </a>

        </div>

      </div>

      <!-- RIGHT -->
      <div class="flex justify-center animate-fadeUp">
        <div class="w-[280px] h-[280px] rounded-2xl border border-white/10 bg-gradient-to-br from-[#7c5cff33] to-transparent"></div>
      </div>

    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="border-t border-white/10 py-20 reveal">
    <div class="grid gap-10 lg:grid-cols-2">

      <div>
        <p class="text-sm uppercase tracking-widest text-white/60">About</p>
        <h2 class="mt-3 text-3xl font-bold text-white">Chi sono</h2>
      </div>

      <div class="space-y-5 leading-8 text-white/60">
        <p>Sono una sviluppatrice con background in ingegneria energetica.</p>
        <p>Creo interfacce web pulite, moderne e accessibili con Astro e Tailwind CSS.</p>
      </div>

    </div>
  </section>

  <!-- SKILLS -->
  <section id="skills" class="border-t border-white/10 py-20 reveal">

    <p class="text-sm uppercase tracking-widest text-white/60">Skills</p>

    <h2 class="mt-3 text-3xl font-bold text-white">Tecnologie</h2>

    <div class="mt-10 grid gap-6 md:grid-cols-2">

      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur">
        <h3 class="font-semibold text-white">Development</h3>

        <div class="mt-4 flex flex-wrap gap-2">
          {skills.map((skill) => (
            <span class="rounded-full bg-white/10 px-3 py-2 text-sm text-white/70">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur">
        <h3 class="font-semibold text-white">Strengths</h3>

        <div class="mt-4 space-y-3">
          {strengths.map((item) => (
            <div class="rounded-lg bg-white/10 px-4 py-3 text-white/70">
              {item}
            </div>
          ))}
        </div>
      </div>

    </div>

  </section>

  <!-- MINI PERCORSO -->
  <section class="border-t border-white/10 py-20 reveal">

    <div class="grid gap-6 md:grid-cols-3">

      <article class="reveal rounded-2xl border border-white/10 bg-white/5 p-6 transition hover:-translate-y-2 hover:border-[#7c5cff]/40">
        <p class="text-sm text-white/60">Background</p>
        <h3 class="mt-3 text-xl font-bold text-white">Ingegneria Energetica</h3>
        <p class="mt-4 text-white/60">Formazione tecnica e analitica.</p>
      </article>

      <article class="reveal rounded-2xl border border-white/10 bg-white/5 p-6 transition hover:-translate-y-2 hover:border-[#7c5cff]/40">
        <p class="text-sm text-white/60">Oggi</p>
        <h3 class="mt-3 text-xl font-bold text-white">Frontend Dev</h3>
        <p class="mt-4 text-white/60">Sviluppo web moderno e UX-oriented.</p>
      </article>

      <article class="reveal rounded-2xl border border-white/10 bg-white/5 p-6 transition hover:-translate-y-2 hover:border-[#7c5cff]/40">
        <p class="text-sm text-white/60">Obiettivo</p>
        <h3 class="mt-3 text-xl font-bold text-white">Crescita</h3>
        <p class="mt-4 text-white/60">Unire ingegneria e sviluppo software.</p>
      </article>

    </div>

  </section>

  <!-- PROJECTS -->
  <section id="projects" class="border-t border-white/10 py-20 reveal">

    <p class="text-sm uppercase tracking-widest text-white/60">Projects</p>

    <h2 class="mt-3 text-3xl font-bold text-white">Lavori selezionati</h2>

    <div class="mt-10 grid gap-6 md:grid-cols-2">

      <!-- CARD 1 -->
      <article class="reveal group rounded-2xl border border-white/10 bg-white/5 p-6 transition hover:-translate-y-2 hover:border-[#7c5cff]/40">

        <div class="h-40 rounded-xl bg-gradient-to-br from-[#7c5cff33] to-transparent mb-6"></div>

        <h3 class="text-xl font-bold text-white group-hover:text-[#7c5cff] transition">
          Portfolio Website
        </h3>

        <p class="mt-3 text-white/60 leading-relaxed">
          Sito personale sviluppato con Astro e Tailwind CSS.
        </p>

        <div class="mt-5 flex gap-2 text-xs text-white/60">
          <span class="px-3 py-1 rounded-full bg-white/10">Astro</span>
          <span class="px-3 py-1 rounded-full bg-white/10">Tailwind</span>
        </div>

      </article>

      <!-- CARD 2 -->
      <article class="reveal group rounded-2xl border border-white/10 bg-white/5 p-6 transition hover:-translate-y-2 hover:border-[#7c5cff]/40">

        <div class="h-40 rounded-xl bg-gradient-to-br from-[#7c5cff33] to-transparent mb-6"></div>

        <h3 class="text-xl font-bold text-white group-hover:text-[#7c5cff] transition">
          Contact Form UI
        </h3>

        <p class="mt-3 text-white/60 leading-relaxed">
          Interfaccia form con UX migliorata.
        </p>

        <div class="mt-5 flex gap-2 text-xs text-white/60">
          <span class="px-3 py-1 rounded-full bg-white/10">Astro</span>
          <span class="px-3 py-1 rounded-full bg-white/10">Zod</span>
        </div>

      </article>

    </div>

  </section>

</Layout>