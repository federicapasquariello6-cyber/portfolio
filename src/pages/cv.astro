---
import Layout from "../layout/Layout.astro";
---

<Layout title="CV | Federica Pasquariello">

  <section class="py-20">

    <!-- HEADER -->
    <div class="max-w-3xl">
      <p class="text-sm uppercase tracking-widest text-blue-600 animate-fade-in">
        Curriculum Vitae
      </p>

      <h1 class="mt-3 text-4xl font-bold text-slate-900 sm:text-5xl animate-slide-up">
        Federica Pasquariello
      </h1>

      <p class="mt-4 text-lg leading-8 text-slate-600 animate-fade-in">
        Laureata in Ingegneria Energetica con focus su sviluppo frontend e tecnologie web moderne.
      </p>
    </div>

    <!-- TIMELINE -->
    <div class="mt-16 relative">

      <!-- linea verticale -->
      <div class="absolute left-4 top-0 h-full w-px bg-slate-200"></div>

      <div class="space-y-12">

        <!-- 1 -->
        <div class="relative pl-12 animate-slide-up">
          <span class="absolute left-2 top-1.5 h-4 w-4 rounded-full bg-blue-600"></span>

          <h2 class="text-xl font-semibold text-slate-900">
            Formazione universitaria
          </h2>

          <p class="mt-2 text-slate-600 leading-7">
            Laureata in Ingegneria Energetica con preparazione nelle discipline matematiche, fisiche,
            energetiche ed elettrotecniche. Tesi incentrata sull’ambito elettrotecnico.
          </p>
        </div>

        <!-- 2 -->
        <div class="relative pl-12 animate-slide-up">
          <span class="absolute left-2 top-1.5 h-4 w-4 rounded-full bg-blue-600"></span>

          <h2 class="text-xl font-semibold text-slate-900">
            Competenze ambientali
          </h2>

          <p class="mt-2 text-slate-600 leading-7">
            Certificato in valutazione e gestione degli impatti ambientali delle attività produttive,
            con competenze in monitoraggio ambientale, analisi dei dati e indicatori di performance.
          </p>
        </div>

        <!-- 3 -->
        <div class="relative pl-12 animate-slide-up">
          <span class="absolute left-2 top-1.5 h-4 w-4 rounded-full bg-blue-600"></span>

          <h2 class="text-xl font-semibold text-slate-900">
            Social Media Management
          </h2>

          <p class="mt-2 text-slate-600 leading-7">
            Attestato in Social Media Manager con competenze nella gestione dei contenuti digitali
            e strategie di comunicazione sui principali canali social.
          </p>
        </div>

        <!-- 4 -->
        <div class="relative pl-12 animate-slide-up">
          <span class="absolute left-2 top-1.5 h-4 w-4 rounded-full bg-blue-600"></span>

          <h2 class="text-xl font-semibold text-slate-900">
            Tirocinio – URTI Re Project S.r.l.
          </h2>

          <p class="mt-2 text-slate-600 leading-7">
            Supporto alle attività di progettazione e analisi territoriale, con utilizzo di planimetrie,
            dati nazionali e strumenti tecnici per lo studio del territorio.
          </p>
        </div>

        <!-- 5 -->
        <div class="relative pl-12 animate-slide-up">
          <span class="absolute left-2 top-1.5 h-4 w-4 rounded-full bg-blue-600"></span>

          <h2 class="text-xl font-semibold text-slate-900">
            Tutor scolastico
          </h2>

          <p class="mt-2 text-slate-600 leading-7">
            Attività di supporto allo studio e tutoraggio per studenti, con focus su materie scientifiche
            e metodo di apprendimento.
          </p>
        </div>

      </div>
    </div>

  </section>

</Layout>