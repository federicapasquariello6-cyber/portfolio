---
import Layout from "../layout/Layout.astro";
---

<Layout title="CV | Federica Pasquariello">

  <section class="py-20">

    <!-- HEADER -->
    <div class="max-w-3xl">

      <p class="text-sm uppercase tracking-widest text-white/60 animate-fadeUp">
        Curriculum Vitae
      </p>

      <h1 class="mt-3 text-4xl font-bold text-white sm:text-5xl animate-fadeUp">
        Federica Pasquariello
      </h1>

      <p class="mt-4 text-lg leading-8 text-white/60 animate-fadeUp">
        Laureata in Ingegneria Energetica con focus su sviluppo frontend e tecnologie web moderne.
      </p>

    </div>

    <!-- TIMELINE -->
    <div class="mt-16 relative">

      <!-- LINEA -->
      <div class="absolute left-4 top-0 h-full w-px bg-white/10"></div>

      <div class="space-y-12">

        <!-- ITEM 1 -->
        <div class="relative pl-12 reveal">

          <span class="absolute left-2 top-1.5 h-4 w-4 rounded-full bg-[#7c5cff] shadow-[0_0_20px_rgba(124,92,255,0.6)]"></span>

          <h2 class="text-xl font-semibold text-white">
            Formazione universitaria
          </h2>

          <p class="mt-2 text-white/60 leading-7">
            Laureata in Ingegneria Energetica con preparazione in matematica, fisica ed elettrotecnica.
          </p>

        </div>

        <!-- ITEM 2 -->
        <div class="relative pl-12 reveal">

          <span class="absolute left-2 top-1.5 h-4 w-4 rounded-full bg-[#7c5cff] shadow-[0_0_20px_rgba(124,92,255,0.6)]"></span>

          <h2 class="text-xl font-semibold text-white">
            Competenze ambientali
          </h2>

          <p class="mt-2 text-white/60 leading-7">
            Certificazione in gestione impatti ambientali, analisi dati e monitoraggio.
          </p>

        </div>

        <!-- ITEM 3 -->
        <div class="relative pl-12 reveal">

          <span class="absolute left-2 top-1.5 h-4 w-4 rounded-full bg-[#7c5cff] shadow-[0_0_20px_rgba(124,92,255,0.6)]"></span>

          <h2 class="text-xl font-semibold text-white">
            Social Media Management
          </h2>

          <p class="mt-2 text-white/60 leading-7">
            Gestione contenuti digitali e strategie di comunicazione social.
          </p>

        </div>

        <!-- ITEM 4 -->
        <div class="relative pl-12 reveal">

          <span class="absolute left-2 top-1.5 h-4 w-4 rounded-full bg-[#7c5cff] shadow-[0_0_20px_rgba(124,92,255,0.6)]"></span>

          <h2 class="text-xl font-semibold text-white">
            Tirocinio – URTI Re Project S.r.l.
          </h2>

          <p class="mt-2 text-white/60 leading-7">
            Supporto progettazione e analisi territoriale con dati tecnici e planimetrie.
          </p>

        </div>

        <!-- ITEM 5 -->
        <div class="relative pl-12 reveal">

          <span class="absolute left-2 top-1.5 h-4 w-4 rounded-full bg-[#7c5cff] shadow-[0_0_20px_rgba(124,92,255,0.6)]"></span>

          <h2 class="text-xl font-semibold text-white">
            Tutor scolastico
          </h2>

          <p class="mt-2 text-white/60 leading-7">
            Supporto allo studio in materie scientifiche e metodo di apprendimento.
          </p>

        </div>

      </div>
    </div>

  </section>

</Layout>